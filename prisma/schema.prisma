generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  stravaId     String   @unique
  name         String
  firstName    String
  lastName     String
  profilePic   String?
  city         String?
  country      String?
  accessToken        String
  refreshToken       String
  tokenExpiry        DateTime
  needsReconnect     Boolean  @default(false)
  stravaLastSyncAt   DateTime?
  waiverAcceptedAt   DateTime?
  createdAt          DateTime @default(now())

  participations EventParticipant[]
  bestEfforts    BestEffort[]
}

model BestEffort {
  id              String   @id @default(cuid())
  userId          String
  distanceMeters  Int
  timeSecs        Int
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, distanceMeters])
}

model Event {
  id          String   @id @default(cuid())
  name        String
  distanceKm  Float
  date        DateTime
  windowStart DateTime
  windowEnd   DateTime
  location    String?
  inviteCode  String   @unique @default(cuid())
  createdBy   String
  createdAt   DateTime @default(now())

  participants EventParticipant[]
  raceCard     RaceCard?
  reactions    Reaction[]
}

model Reaction {
  id         String   @id @default(cuid())
  eventId    String
  targetType String   // "runner" | "tipster"
  targetId   String   // EventParticipant.id for runner, Event.id for tipster
  emoji      String
  authorId   String
  authorName String
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, authorId, emoji])
  @@index([eventId])
}

model RaceCard {
  id          String   @id @default(cuid())
  eventId     String   @unique
  commentary  String   @db.Text
  generatedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventParticipant {
  id               String    @id @default(cuid())
  eventId          String
  userId           String
  predictedTimeSecs  Int?
  actualTimeSecs     Int?
  vdotPredictedSecs  Int?
  personalBestSecs   Int?
  stravaActivityId   BigInt?
  resultFetchedAt    DateTime?
  joinedAt         DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}
